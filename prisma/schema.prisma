generator client {
  provider = "prisma-client-js"
  
}

datasource db {
  provider = "postgresql"
   url      = env("DATABASE_URL") 
}

enum Role {
  ADMIN
  USER
}

model User {
  id         String     @id @default(cuid())
  phone      String     @unique
  name       String
  password   String
  role       Role       @default(USER)
  properties Property[]
  cars       Car[]
}

enum PropertyType {
  HOUSE
  APARTMENT
  LAND
  BUILDING
}

enum CarType {
  SEDAN
  SUV
  TRUCK
  VAN
  COUPE
  CONVERTIBLE
  OTHER
}

enum FuelType {
  PETROL
  DIESEL
  ELECTRIC
  HYBRID
}

enum TransmissionType {
  MANUAL
  AUTOMATIC
}

enum TransactionType {
  FOR_SALE
  FOR_RENT
}

enum ListingStatus {
  PENDING
  PUBLISHED
  REJECTED
}

enum RentalPeriod {
  DAILY
  MONTHLY
}

model Property {
  id              String          @id @default(cuid())
  type            PropertyType
  transactionType TransactionType @default(FOR_SALE)
  price           Float
  location    String
  locationAr  String
  bedrooms    Int?
  bathrooms   Int?
  area        Float
  image       String       // Cloudinary URL
  images      String[]     // Additional Cloudinary Gallery URLs
  featured    Boolean      @default(false)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  
  // Nouveaux champs
 
  announcementDate  DateTime?
  dossierType       String?
  resource          String?
  whatsapp          String?
  status            ListingStatus @default(PUBLISHED)
  paymentScreenshot String?
  rentalPeriod      RentalPeriod?

  // Relation
  userId      String
  author      User         @relation(fields: [userId], references: [id])
  @@index([type])
  @@index([transactionType])
  @@index([location])
  @@index([createdAt])
}

model Car {
  id              String           @id @default(cuid())
  type            CarType
  transactionType TransactionType  @default(FOR_SALE)
  price           Float
  location        String
  locationAr      String
  brand           String
  carModel        String
  year            Int
  mileage         Int?
  fuel            FuelType
  transmission    TransmissionType @default(AUTOMATIC)
  color           String?
  image           String
  images          String[]
  featured        Boolean          @default(false)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  announcementDate  DateTime?
  dossierType       String?
  resource          String?
  whatsapp          String?
  status            ListingStatus @default(PUBLISHED)
  paymentScreenshot String?
  rentalPeriod      RentalPeriod?

  userId  String
  author  User   @relation(fields: [userId], references: [id])

  @@index([type])
  @@index([transactionType])
  @@index([location])
  @@index([createdAt])
  @@index([brand])
}
